# ============================================================
#  FICHIER D'EXEMPLE - Copie en .env et remplis les valeurs
# ============================================================

# === BASE DE DONNÉES (Supabase) ===
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB]?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres:[MOT_DE_PASSE]@[HOST].supabase.co:5432/postgres"

# === SECRETS APP ===
NEXTAUTH_URL="https://[TON-APP].vercel.app"
NEXTAUTH_SECRET="[GÉNÈRE UN SECRET ALÉATOIRE - 32 chars min]"

# === GEMINI AI ===
GEMINI_API_KEY="[TA_CLE_API_GEMINI]"

# === FRONTEND (CORS) ===
FRONTEND_URL="https://[TON-APP].vercel.app"

# === PORT (Render le définit automatiquement) ===
PORT=3001

# === CLOUDINARY (uniquement pour le script de migration) ===
# Trouvables sur https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="[TON_CLOUD_NAME]"
CLOUDINARY_API_KEY="[TA_API_KEY]"
CLOUDINARY_API_SECRET="[TON_API_SECRET]"

# === DIGITALOCEAN SPACES ===
DO_SPACES_ACCESS_KEY="[TA_SPACES_ACCESS_KEY]"
DO_SPACES_SECRET_KEY="[TA_SPACES_SECRET_KEY]"
DO_SPACES_BUCKET="[TON_BUCKET]"
DO_SPACES_REGION="fra1"
MEDIA_BASE_URL="https://[TON_BUCKET].fra1.digitaloceanspaces.com"

# === IMGPROXY ===
IMGPROXY_KEY="[CLE_HEX_IMGPROXY]"
IMGPROXY_SALT="[SALT_HEX_IMGPROXY]"
